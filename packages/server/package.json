{
  "name": "atc-kanban",
  "version": "0.6.0",
  "description": "Multi-agent task orchestration system with kanban board — MCP server + HTTP dashboard",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "atc-kanban": "./dist/cli.js",
    "atc": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "copy:dashboard": "node scripts/copy-dashboard.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "task-management",
    "kanban",
    "orchestration"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JSCOP/atc-kanban.git"
  },
  "homepage": "https://github.com/JSCOP/atc-kanban#readme",
  "bugs": {
    "url": "https://github.com/JSCOP/atc-kanban/issues"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.8.0",
    "drizzle-orm": "^0.38.0",
    "env-paths": "^4.0.0",
    "hono": "^4.7.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@atc/core": "workspace:*",
    "@types/ws": "^8.5.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
